# GoAegis local development environment
# Copy this file to `.env` for local runs. Never commit `.env` or `.env.production`.

ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Backend and persistence
DATABASE_URL=postgresql://localhost/goaegis
# Fill this locally. Never commit a real key.
GEMINI_API_KEY=
SENTRY_DSN=

# GitHub review posting
# Fill this locally. Never commit a real token.
GOAEGIS_GITHUB_TOKEN=
GOAEGIS_GITHUB_API_URL=https://api.github.com

# Telemetry
GOAEGIS_TELEMETRY_ENABLED=true

# Extension and MCP
GOAEGIS_API_BASE_URL=http://localhost:8000
