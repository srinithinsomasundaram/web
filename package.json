{
  "name": "goaegis",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "check": "npm run check --workspaces",
    "test": "npm run test --workspaces",
    "dev:backend": "bash ./scripts/dev-backend.sh",
    "package:extension": "npm run package --workspace @goaegis/extension"
  }
}
